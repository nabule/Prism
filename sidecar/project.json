{
  "name": "sidecar",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run pytest",
        "cwd": "."
      }
    },
    "compile": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run python -m compileall -q src tests",
        "cwd": "."
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose build sidecar sidecar-worker",
        "cwd": "."
      }
    },
    "up": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose up -d",
        "cwd": "."
      }
    },
    "probe-memos": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run python -m memosima.memos.probe",
        "cwd": "."
      }
    }
  }
}
